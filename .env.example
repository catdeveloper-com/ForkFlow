# Локальная конфигурация ForkFlow.
# Скопируй этот файл в .env перед запуском Docker Compose или сервисов.

FORKFLOW_POSTGRES_DB=forkflow_auth
FORKFLOW_POSTGRES_USER=forkflow
FORKFLOW_POSTGRES_PASSWORD=local-development-only-change-me
FORKFLOW_POSTGRES_PORT=5432

FORKFLOW_REDIS_PORT=6379

AUTH_SERVICE_TITLE=ForkFlow Auth Service
AUTH_SERVICE_VERSION=0.1.0
